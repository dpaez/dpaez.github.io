---
import Layout from "@/layouts/Layout.astro"
import { ThemeNavShell } from "@/components/ui/ThemeNavShell"
import { AboutContent } from "@/components/AboutContent"
import { TalksSection } from "@/components/TalksSection"

const currentPath = Astro.url.pathname
---

<Layout 
  title="About | DΞKΔ"
  description="About Diego Paez (DEKA). Background, experience, conference talks, and areas of interest."
>
  <ThemeNavShell client:load currentPath={currentPath} />
  <main transition:animate="slide" class="container py-12">
    <div class="max-w-4xl mx-auto">
      <div class="space-y-12">
        <AboutContent client:load />
        <TalksSection client:load />
      </div>
    </div>
  </main>
  <footer class="border-t border-border py-6 text-center text-sm text-muted-foreground mt-auto">
    <div class="container">
      <p>© {new Date().getFullYear()} DΞKΔ. Built with Astro & React.</p>
    </div>
  </footer>
</Layout>
