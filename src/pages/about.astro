---
import Layout from "@/layouts/Layout.astro"
import { ThemeNavShell } from "@/components/ui/ThemeNavShell"
import { AboutContent } from "@/components/AboutContent"
import { TalksSection } from "@/components/TalksSection"


---

<Layout 
  title="About | D Ξ K Δ"
  description="About Diego Paez (DEKA). Background, experience, conference talks, and areas of interest."
  
>
  <div class="sticky top-0 z-40 h-12">
    <div class="backdrop"></div>
    <div class="backdrop-edge"></div>
    <ThemeNavShell transition:persist="nav" client:only="react" />
  </div>
  <main transition:animate="fade" class=" py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight mb-4">About</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Background, experience and areas of interest.
        </p>
      </div>
      <div class="space-y-12">
        <AboutContent client:load />
      </div>
    </div>
  </main>
</Layout>
