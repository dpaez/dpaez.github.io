---
import Layout from "@/layouts/Layout.astro"
import { ThemeNavShell } from "@/components/ui/ThemeNavShell"
import { Card } from "local-components/card"

const currentPath = Astro.url.pathname
---

<Layout 
  title="About | DΞKΔ"
  description="About Diego Paez (DEKA). Background, experience, and conference talks."
>
  <ThemeNavShell client:load currentPath={currentPath} />
  <main transition:animate="slide" class="container py-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold tracking-tight mb-8 text-center">About</h1>
      
      <div class="space-y-8">
        <Card title="Bio" description="Hi, I'm Diego also known as DEKA | DK (he/him). Class '85. Natural from Tierra del Fuego, Patagonia, Argentina." />
        
        <Card title="Background" description="I have a Licentiate's Degree in Computer Science from the National University of La Plata, UNLP - Informática." />
        
        <Card title="Talks" description="Conference talks and workshops coming soon. Including NodeConf Colombia 2019, NodeConf Argentina 2018 & 2016." />
        
        <Card title="Contact" description="You can reach me at diego at geutstudio . com">
          <div class="flex gap-4 mt-4">
            <a href="https://twitter.com/carax" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Twitter</a>
            <a href="https://github.com/dpaez" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GitHub</a>
            <a href="https://geutstudio.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GEUT</a>
            <a href="https://sher.geutstudio.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">SHER</a>
          </div>
        </Card>
      </div>
    </div>
  </main>
  <footer class="border-t border-border py-6 text-center text-sm text-muted-foreground mt-auto">
    <div class="container">
      <p>© {new Date().getFullYear()} DΞKΔ. Built with Astro & React.</p>
    </div>
  </footer>
</Layout>
