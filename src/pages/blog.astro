---
import { getCollection } from 'astro:content'
import Layout from "@/layouts/Layout.astro"
import { ThemeNavShell } from "@/components/ui/ThemeNavShell"
import { BlogList } from "@/components/BlogList"

const posts = await getCollection('blog', ({ data }: { data: { draft: boolean } }) => !data.draft)
---

<Layout 
  title="Blog | D Ξ K Δ"
  description="Technical blog by Diego Paez (DEKA). Thoughts on P2P systems, distributed computing, and software development."
  
>
  <div class="sticky top-0 z-40 h-12">
    <div class="backdrop"></div>
    <div class="backdrop-edge"></div>
    <ThemeNavShell transition:persist="nav" client:only="react" />
  </div>
  <main transition:animate="fade" class=" py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight mb-4">Blog</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Thoughts on P2P systems, distributed computing, and software development. 
          Lessons learned from building real systems.
        </p>
      </div>
      
      <BlogList client:load posts={posts} />
    </div>
  </main>
</Layout>
